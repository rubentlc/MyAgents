#compdef igit

_igit() {
  # ----------------------------
  # first argument = command
  # ----------------------------
  if (( CURRENT == 2 )); then
    local -a names descs

    names=(feature hotfix bugfix spike)
    descs=(
      'feature     -- igit feature <number?> <name?> [-b? <branch>]'
      'hotfix      -- igit hotfix <number?> <name?> [-b? <branch>]'
      'bugfix      -- igit bugfix <number?> <name?> [-b? <branch>]'
      'spike       -- igit spike <number?> <name?> [-b? <branch>]'
    )
    compadd -l -X 'Create new worktree and switch to it' -V 'create' -d descs -- "${names[@]}"

    names=(open delete list)
    descs=(
      'open    -- igit open [-w? <worktree>]'
      'delete  -- igit delete [-w? <worktree>]'
      'list    -- list all worktrees'
    )
    compadd -l -X $'\nOpen, Delete and List:' -V 'open' -d descs -- "${names[@]}"

    names=(commit undo-commit merge-into)
    descs=(
      'commit      -- igit commit [-w? <worktree>] <message>'
      'undo-commit -- igit undo-commit [-w? <worktree>]'
      'merge-into  -- igit merge-into [-w? <worktree>] <branch>'
    )
    compadd -l -X $'\nManage Commits:' -V 'commits' -d descs -- "${names[@]}"

    return
  fi

  local cmd="${words[2]}"

  # ----------------------------
  # WORKTREE COMPLETION SOURCE
  # ----------------------------
  local -a worktrees
  worktrees=(${(f)"$(git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree / {print $2}' \
    | grep '/worktree/' \
    | sed 's#.*/worktree/##')"})

  local -a origin_branches
  origin_branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null \
    | sed 's#^origin/##' \
    | grep -v '^HEAD$')"})

  local -a delete_options
  delete_options=(
    "-w:target worktree"
    "--force:force worktree removal"
  )

  # ----------------------------
  # completion per command
  # ----------------------------

  case "$cmd" in

    open)
      if (( CURRENT == 3 )); then
        _describe 'options' "-w:target worktree"
        _describe 'worktrees' worktrees
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      fi
      ;;

    delete)
      if (( CURRENT == 3 )); then
        _describe 'options' delete_options
        _describe 'worktrees' worktrees
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "--force" ]]; then
        _describe 'options' "-w:target worktree"
        _describe 'worktrees' worktrees
      elif (( CURRENT == 5 )) && [[ "${words[3]}" == "--force" ]] && [[ "${words[4]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      fi
      ;;

    commit)
      if (( CURRENT == 3 )); then
        _describe 'options' "-w:target worktree"
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      fi
      ;;

    undo-commit)
      if (( CURRENT == 3 )); then
        _describe 'options' "-w:target worktree"
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      fi
      ;;

    merge-into)
      if (( CURRENT == 3 )); then
        _describe 'options' "-w:target worktree"
        _describe 'branches' origin_branches
      elif (( CURRENT == 4 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'worktrees' worktrees
      elif (( CURRENT == 5 )) && [[ "${words[3]}" == "-w" ]]; then
        _describe 'branches' origin_branches
      fi
      ;;

    feature|hotfix|bugfix|spike)
      # no completion for creation name
      ;;

  esac
}

_igit "$@"