{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/guard-dangerous-commands.sh",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/frontend-build-on-stop.sh",
        "timeout": 1800
      }
    ]
  }
}